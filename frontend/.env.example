# Firebase — get these from Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Spotify — get from developer.spotify.com > Your App
VITE_SPOTIFY_CLIENT_ID=
# Must match the Redirect URI registered in your Spotify app settings
VITE_SPOTIFY_REDIRECT_URI=https://your-vercel-domain.vercel.app/customer

# Stripe — get from dashboard.stripe.com > Developers > API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
